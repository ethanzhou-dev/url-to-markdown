{
  "manifest_version": 3,
  "name": "URL to Markdown Converter",
  "version": "1.0.0",
  "description": "提取网页正文并转换为干净的 Markdown 格式，丢弃广告、菜单等无关内容。",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}